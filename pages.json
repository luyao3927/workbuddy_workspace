{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^app-(.*)": "@/components/common/app-$1.vue",
      "^dish-(.*)": "@/components/dish/dish-$1.vue",
      "^cart-(.*)": "@/components/cart/cart-$1.vue",
      "^collage-(.*)": "@/components/collage/collage-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "私房菜谱",
        "navigationStyle": "custom",
        "enablePullDownRefresh": true,
        "backgroundColor": "@bg-primary"
      }
    },
    {
      "path": "pages/dish-detail/index",
      "style": {
        "navigationBarTitleText": "菜品详情",
        "navigationStyle": "custom",
        "backgroundColor": "@bg-primary"
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "确认订单",
        "navigationStyle": "custom",
        "backgroundColor": "@bg-primary"
      }
    },
    {
      "path": "pages/order-success/index",
      "style": {
        "navigationBarTitleText": "下单成功",
        "navigationStyle": "custom",
        "backgroundColor": "@bg-primary"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "@nav-text",
    "navigationBarTitleText": "",
    "navigationBarBackgroundColor": "@nav-bg",
    "backgroundColor": "@bg-primary",
    "backgroundTextStyle": "@bg-text-style"
  },
  "condition": {
    "current": 0,
    "list": []
  }
}
